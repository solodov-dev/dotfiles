URxvt.font: xft:firacode:size=10, xft:Font Awesome 5 Free Solid:style=Solid:size=10, xft:Inconsolata Nerd Font Mono:size=10
URxvt.scrollBar: false

! Cursor
URxvt.cursorBlink: true
URxvt.cursorColor: #BD93F9

! Dracula Xresources palette
*.foreground: #ffffff
*.background: #282A36
*.color0:     #000000
*.color8:     #4D4D4D
*.color1:     #FF5555
*.color9:     #FF6E67
*.color10:    #50FA7B
*.color14:    #5AF78E
*.color3:     #F1FA8C
*.color11:    #F4F99D
*.color4:     #BD93F9
*.color12:    #CAA9FA
*.color5:     #FF79C6
*.color13:    #FF92D0
*.color2:     #8BE9FD
*.color6:     #9AEDFE
*.color7:     #BFBFBF
*.color15:    #E6E6E6

! Extensions
URxvt.perl-ext-common: default,matcher,font-size
URxvt.url-launcher: /usr/bin/xdg-open
URxvt.matcher.button: 1
