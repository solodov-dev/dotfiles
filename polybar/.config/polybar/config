[colors]
background = #282828
background-alt = #928374
foreground = #f8f8f2
purple = #d79921
green = #98971a
pink = #fb4934
red = #cc241d

[bar/bar1]
;monitor = ${env:MONITOR:HDMI-1}
width = 100%
height = 27
;offset-x = 1%
;offset-y = 1%
fixed-center = false

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 3 
line-color = #f00

border-size = 3
border-color = #00000000

padding-left = 0
padding-right = 2

module-margin-left = 1
module-margin-right = 2

font-0 = Cantarell:style=Solid:size=10;4
font-1 = FontAwesome5Free:style=Solid:size=10;4
font-2 = FontAwesome5Free:style=Regular:size=10;4
font-3 = FontAwesome5Brands:style=Regular:size=10;4
;font-4 = unifont:fontformat=truetype:size=10:antialias=false;0
;font-5 = siji:pixelsize=16;1

modules-left = bspwm i3 xwindow
modules-center = mpd
modules-right = filesystem xbacklight alsa pulseaudio xkeyboard memory cpu wlan eth battery temperature date powermenu

tray-position = right
tray-padding = 2
;tray-background = #0063ff

;wm-restack = bspwm
;wm-restack = i3

;override-redirect = true

;scroll-up = bspwm-desknext
;scroll-down = bspwm-deskprev

;scroll-up = i3wm-wsnext
;scroll-down = i3wm-wsprev

cursor-click = pointer
cursor-scroll = ns-resize

[module/xwindow]
type = internal/xwindow
label = %title%
label-maxlen = 80
label-foreground = ${colors.pink}
label-padding = 3

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

format-prefix = "ÔĄú "
format-prefix-foreground = ${colors.purple}

label-layout = %layout%

label-indicator-padding = 2
label-indicator-margin = 1
label-indicator-background = ${colors.pink}

[module/bspwm]
type = internal/bspwm

label-focused = %index%
label-focused-background = ${colors.background-alt}
label-focused-padding = 2

label-occupied = %index%
label-occupied-padding = 2

label-urgent = %index%!
label-urgent-background = ${colors.red}
label-urgent-padding = 2

label-empty = %index%
label-empty-foreground = ${colors.purple}
label-empty-padding = 2

; Separator in between workspaces
; label-separator = |

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
index-sort = true
wrapping-scroll = false

; Only show workspaces on the same output as the bar
;pin-workspaces = true

label-mode-padding = 2
label-mode-foreground = #000
label-mode-background = ${colors.green}

; focused = Active workspace on focused monitor
label-focused = %index%
label-focused-underline = ${colors.green}
label-focused-background = ${colors.background-alt}
label-focused-padding = 2

; unfocused = Inactive workspace on any monitor
label-unfocused = %index%
label-unfocused-padding = 2

; visible = Active workspace on unfocused monitor
label-visible = %index%
label-visible-background = ${self.label-focused-background}
label-visible-padding = ${self.label-focused-padding}

; urgent = Workspace with urgency hint set
label-urgent = %index%
label-urgent-background = ${colors.red}
label-urgent-padding = 2

; Separator in between workspaces
; label-separator = |


[module/mpd]
type = internal/mpd
format-online = <label-song>  <icon-prev> <icon-stop> <toggle> <icon-next>

icon-prev = ÓāĖ
icon-stop = Óāô
icon-play = Óāö
icon-pause = Óāõ
icon-next = Óāú

label-song-maxlen = 25
label-song-ellipsis = true

[module/xbacklight]
type = internal/xbacklight

format = <ramp> > <label> % 
format-foreground = ${colors.purple}
label = %percentage% 
label-foreground = ${colors.foreground}

ramp-0 = ÔÜÜ
ramp-1 = ÔÜÖ

[module/backlight-acpi]
inherit = module/xbacklight
type = internal/backlight
card = intel_backlight

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "Ôčõ"
format-prefix-foreground = ${colors.purple}
label = %percentage:2%%

[module/memory]
type = internal/memory
interval = 2
format-prefix = "ÔĒł "
format-prefix-foreground = ${colors.purple}
label = %percentage_used%%

[module/wlan]
type = internal/network
interface = net1
interval = 3.0

format-connected = <ramp-signal> <label-connected>
label-connected = %essid%

format-disconnected =
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.purple}

ramp-signal-1 = Ôö™
ramp-signal-2 = Ôöę
ramp-signal-3 = Ôáę
ramp-signal-foreground = ${colors.purple}

[module/eth]
;type = internal/network
;interface = wlp3s0
;interval = 3.0

;format-connected-prefix = "ÓÜú "
;format-connected-prefix-foreground = ${colors.purple}
;label-connected = %local_ip%

format-disconnected =
;format-disconnected = <label-disconnected>
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.purple}

[module/date]
type = internal/date
interval = 5

date =
date-alt = " %Y-%m-%d"

time = %H:%M
time-alt = %H:%M:%S

format-prefix = ÔÄó
format-prefix-foreground = ${colors.purple}

label = %date% %time%

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <ramp-volume> <label-volume>%
format-volume-foreground = ${colors.purple}
label-volume = %percentage% 
label-volume-foreground = ${root.foreground}

ramp-volume-0 = ÔÄ¶
ramp-volume-1 = ÔÄß
ramp-volume-2 = ÔÄ®

label-muted = Ôö© 
label-muted-foreground = ${colors.pink} 
click-right = pavucontrol &

[module/battery]
type = internal/battery
battery = BAT0
adapter = ADP1
full-at = 98

format-charging = <animation-charging> <label-charging>

format-discharging = <animation-discharging> <label-discharging>

format-full-prefix = "ÔČÄ  "
format-full-prefix-foreground = ${colors.purple}

ramp-capacity-0 = Óą∂
ramp-capacity-1 = Óą∑
ramp-capacity-2 = Óął
ramp-capacity-foreground = ${colors.purple}

animation-charging-0 = ÔČĄ  
animation-charging-1 = ÔČÉ  
animation-charging-2 = ÔČā  
animation-charging-3 = ÔČĀ  
animation-charging-4 = ÔČÄ  
animation-charging-foreground = ${colors.purple}
animation-charging-framerate = 750

animation-discharging-0 = ÔČĀ 
animation-discharging-1 = ÔČĀ 
animation-discharging-2 = ÔČā 
animation-discharging-3 = ÔČÉ 
animation-discharging-4 = ÔČĄ 
animation-discharging-foreground = ${colors.purple}
animation-discharging-framerate = 750

[module/temperature]
type = internal/temperature
thermal-zone = 0
warn-temperature = 60

format = <ramp> <label>
format-warn = <ramp> <label-warn>

label = %temperature-c%
label-warn = %temperature-c%
label-warn-foreground = ${colors.pink}

ramp-0 = Ôčä
ramp-1 = ÔčČ
ramp-2 = Ôčą
ramp-foreground = ${colors.purple}

[module/powermenu]
type = custom/menu

expand-right = true

format-spacing = 1

label-open = ÔÄĎ
label-open-foreground = ${colors.pink}
label-close = Ôēö 
label-close-foreground = ${colors.pink}
label-separator = |
label-separator-foreground = ${colors.purple}

menu-0-0 = Ôč™ reboot
menu-0-0-exec = menu-open-1
menu-0-1 = ÔÄĎ poweroff
menu-0-1-exec = menu-open-2

menu-1-0 = Ôč™ reboot
menu-1-0-exec = reboot

menu-2-0 = ÔÄĎ poweroff 
menu-2-0-exec = poweroff

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
;pseudo-transparency = false

[global/wm]
margin-top = 5
margin-bottom = 5

